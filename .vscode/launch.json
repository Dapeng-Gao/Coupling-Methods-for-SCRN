{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (clang++)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/Build/${fileBasenameNoExtension}",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "externalConsole": false,
            "MIMode": "lldb",
            "preLaunchTask": "build & run cpp (clang++)",
            "setupCommands": [
                {
                    "description": "Enable pretty printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}